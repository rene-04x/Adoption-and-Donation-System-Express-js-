sql query to create the adoptions_applications table:
CREATE TABLE adoption_applications (
    id INT AUTO_INCREMENT PRIMARY KEY,
    user_id INT NOT NULL, -- I-link ito sa iyong users table
    pet_name VARCHAR(100) NOT NULL,
    last_name VARCHAR(100) NOT NULL,
    given_name VARCHAR(100) NOT NULL,
    middle_name VARCHAR(100),
    birthdate DATE NOT NULL,
    email VARCHAR(150) NOT NULL,
    phone VARCHAR(20) NOT NULL,
    fb_link TEXT NOT NULL,
    contact_method ENUM('Email', 'FB/Messenger') DEFAULT 'Email',
    employment_status ENUM('Employed', 'Self-Employed', 'Student', 'Unemployed') NOT NULL,
    pet_experience TEXT,
    living_type VARCHAR(255), -- Dito papasok ang "House (Owned), Apartment, etc."
    fenced_yard ENUM('Yes', 'No') DEFAULT 'No',
    pets_allowed ENUM('Yes', 'No') DEFAULT 'Yes',
    reason_adoption TEXT NOT NULL,
    
    -- Status and Timestamps
    status ENUM('Submitted', 'Active', 'Interview', 'Approved', 'Success', 'Cancelled') DEFAULT 'Submitted',
    date_applied TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    
    -- Document Paths (Storage paths of images)
    valid_id_path VARCHAR(255),
    proof_address_path VARCHAR(255),
    
    -- Admin Specific Fields
    admin_notes TEXT,
    interview_date DATETIME, 
    interview_method VARCHAR(100),
    
    -- Foreign Key (Optional but recommended)
    -- FOREIGN KEY (user_id) REFERENCES users(id) ON DELETE CASCADE
) ENGINE=InnoDB;
